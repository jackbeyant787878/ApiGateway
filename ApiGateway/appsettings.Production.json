{
  "AllowedHosts": "*",

  // Serilog 高级日志配置
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  // 注册中心配置
  "Consul": {
    "Address": "",
    //网关自身注册配置
    "Service": {
      "Name": "", // 注册到 Consul 中的服务名称
      "Address": "", 
      "Port": 5040, // 网关运行的端口
      "HealthCheckPath": "" //Consul 发起健康检查的路由
    }
  },

  // 权限中心集成配置（无状态验签）
  "Jwt": {
    "Issuer": ""
  },
  "KeySettings": {
    "BaseDirectory": "",
    "Encryption": {
      "PrivateKeyFile": "",
      "KeyIdFile": ""
    },
    "EncryptionKeyLifetimeDays": 180,
    "CheckIntervalDays": 1
  },
  // YARP 基础网络调优（防止高并发下 502）
  "GatewaySettings": {
    "MaxConnectionsPerServer": 5000,
    "HttpRequestTimeoutSeconds": 30
  }
}
{
  "AllowedHosts": "*",

  // Serilog 高级日志配置
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  // 注册中心配置
  "Consul": {
    "Address": "http://127.0.0.1:8500",
    // 新增：网关自身注册配置
    "Service": {
      "Name": "micro-gateway", // 注册到 Consul 中的服务名称
      "Address": "127.0.0.1", // 网关所在服务器的内网IP（目前单机先写127.0.0.1）
      "Port": 5000, // 网关运行的端口
      "HealthCheckPath": "/gateway/health" // Consul 发起健康检查的路由
    }
  },

  // 权限中心集成配置（无状态验签）
  "Jwt": {
    "PublicKeyPath": "Configurations/auth_public_key.pem",
    "Issuer": "your-ddd-auth-center"
  },

  // YARP 基础网络调优（防止高并发下 502）
  "GatewaySettings": {
    "MaxConnectionsPerServer": 5000,
    "HttpRequestTimeoutSeconds": 30
  }
}